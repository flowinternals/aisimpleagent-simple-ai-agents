PORT=8787

# Public UI: base URL for browser calls to this app's API (never put provider secrets here).
VITE_API_BASE_URL=

CORS_ORIGIN=http://localhost:5173

# API loads `.env`, `.env.local`, then Assets/security/openai.provider.runtime (OPENAI_* only).
# Mock vs live is chosen per request from the UI (providerMode). Variables below are server-only.

# --- OpenAI live (Express only; put secrets in .env.local, do not commit) ---
# Create a key at https://platform.openai.com/api-keys -- never prefix with VITE_.
OPENAI_API_KEY=

# Optional overrides:
# OPENAI_ORG_ID=
# OPENAI_PROJECT=
# OPENAI_BASE_URL=https://api.openai.com/v1
# Must match OpenAI Images API models you are allowed to use (default gpt-image-1.5).
# OPENAI_IMAGE_MODEL=gpt-image-1.5
# GPT image quality for testing cost control: low, medium, or high (default low).
# OPENAI_IMAGE_QUALITY=low
