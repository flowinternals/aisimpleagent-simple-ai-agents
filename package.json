{
  "name": "aisimpleagent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:ui": "vite",
    "dev:api": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test shared/*.test.js server/**/*.test.js tests/regression/lib/*.test.js && vitest run",
    "test:unit": "node --test shared/*.test.js server/**/*.test.js tests/regression/lib/*.test.js",
    "test:readiness": "node tests/regression/verify-generation-readiness.mjs",
    "test:readiness:live": "node tests/regression/verify-generation-readiness.mjs --live",
    "test:auth": "node tests/regression/verify-demo-auth.mjs",
    "test:authorization": "node tests/regression/verify-authorization.mjs",
    "test:validation": "node tests/regression/verify-validation.mjs",
    "test:abuse": "node tests/regression/verify-abuse-controls.mjs",
    "test:transport": "node tests/regression/verify-transport.mjs",
    "test:section12": "node tests/regression/verify-section12-surfaces.mjs",
    "test:secrets": "node tests/regression/verify-secret-exposure.mjs",
    "check:text": "node scripts/check-text-hygiene.js",
    "secrets:scan": "node scripts/run-gitleaks.mjs detect --source . --verbose --no-git",
    "secrets:scan:history": "node scripts/run-gitleaks.mjs detect --source . --verbose",
    "secrets:scan:tracked": "node scripts/run-gitleaks.mjs tracked"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^3.0.5"
  }
}
